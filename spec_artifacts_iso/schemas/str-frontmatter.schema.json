{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id",
    "title",
    "type"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^StR-[0-9]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "const": "StR"
    },
    "object": {
      "type": "string"
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target",
          "type"
        ],
        "additionalProperties": false,
        "properties": {
          "target": {
            "type": "string",
            "pattern": "^ix://"
          },
          "type": {
            "type": "string"
          },
          "cardinality": {
            "type": "string"
          }
        }
      }
    }
  }
}